# Simple threshold-based spike detector
THRESHOLD = 0.5  # value above which signal is a "spike"

previous_state = False  # False = baseline, True = in spike
output_fired = False

for sample in signal:
    current_state = sample > THRESHOLD
    
    # Rising edge: was baseline, now spike
    if current_state and not previous_state:
        fire_output()          # ← triggers ONCE per spike
    
    previous_state = current_state
```

### The State Machine (conceptually)
```
BASELINE ──(signal > threshold)──► SPIKE  → fire output
SPIKE    ──(signal ≤ threshold)──► BASELINE
BASELINE ──(signal ≤ threshold)──► BASELINE (no output)
SPIKE    ──(signal > threshold)──► SPIKE   (no output)

import time

THRESHOLD = 0.5
MIN_SPIKE_GAP = 0.1  # seconds — ignore re-triggers within this window

last_spike_time = -999
in_spike = False

for timestamp, sample in signal:
    above = sample > THRESHOLD
    
    if above and not in_spike:
        time_since_last = timestamp - last_spike_time
        if time_since_last > MIN_SPIKE_GAP:
            fire_output()
            last_spike_time = timestamp
    
    in_spike = above  # update state

